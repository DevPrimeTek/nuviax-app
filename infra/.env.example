# ============================================================
# NUViaX — .env.example
# Copiază ca .env și completează valorile REALE
# NICIODATĂ nu comite .env în git!
# ============================================================

# ── Deployment ──────────────────────────────────────────────
IMAGE_TAG=latest
LETSENCRYPT_EMAIL=admin@nuviax.app

# ── PostgreSQL ───────────────────────────────────────────────
# Generează cu: openssl rand -base64 32
POSTGRES_PASSWORD=qZ6+RUV2tpZXUT/deHFRxVLhqcgBMaiJD9thainEsVg=

# ── Redis ────────────────────────────────────────────────────
# Generează cu: openssl rand -base64 32
REDIS_PASSWORD=ynFiJH+jqWZrO8DxjNELMtUOoandRpZIPdAY40cpHMk=

# ── JWT (RSA 4096-bit) ───────────────────────────────────────
# Generare:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | base64 -w 0   --> JWT_PRIVATE_KEY
#   cat public.pem  | base64 -w 0   --> JWT_PUBLIC_KEY
JWT_PRIVATE_KEY=BASE64_ENCODED_RSA_PRIVATE_KEY
JWT_PUBLIC_KEY=BASE64_ENCODED_RSA_PUBLIC_KEY

# ── Encryption (AES-256) ─────────────────────────────────────
# Generează cu: openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_64_CHAR_HEX
